sanity.imagePaletteSwatch","background":"#645132","foreground":"#fff","population":3.34,"title":"#fff"},"darkVibrant":{"_type":"sanity.imagePaletteSwatch","background":"#7c3c08","foreground":"#fff","population":0.01,"title":"#fff"},"dominant":{"_type":"sanity.imagePaletteSwatch","background":"#8b7464","foreground":"#fff","population":6.72,"title":"#fff"},"lightMuted":{"_type":"sanity.imagePaletteSwatch","background":"#cbb18f","foreground":"#000","population":1.45,"title":"#fff"},"lightVibrant":{"_type":"sanity.imagePaletteSwatch","background":"#f2cc6f","foreground":"#000","population":0.05,"title":"#000"},"muted":{"_type":"sanity.imagePaletteSwatch","background":"#8b7464","foreground":"#fff","population":6.72,"title":"#fff"},"vibrant":{"_type":"sanity.imagePaletteSwatch","background":"#bf8933","foreground":"#fff","population":6.2,"title":"#fff"}}},"mimeType":"image/png","originalFilename":"Frame 19222 (1).png","path":"images/8qqycr4y/production/ac288e5dbd1272ee0c78d5abe2916f0ba62b078e-4800x2112.png","sha1hash":"ac288e5dbd1272ee0c78d5abe2916f0ba62b078e","size":9208776,"uploadId":"hCVRxqFn40FBTCYIcwhdIB8q3DI8nAEz","url":"https://cdn.sanity.io/images/8qqycr4y/production/ac288e5dbd1272ee0c78d5abe2916f0ba62b078e-4800x2112.png","id":"image-ac288e5dbd1272ee0c78d5abe2916f0ba62b078e-4800x2112-png","parent":null,"children":["19052cd3-f3cc-51bb-b1cc-fd9b29ed6a5f"],"internal":{"type":"SanityImageAsset","contentDigest":"f650d497521a6218dd39de6591554483","counter":6762,"owner":"gatsby-source-sanity"}}},"editorialText":[{"_key":"de7de747b209","_type":"block","children":[{"_key":"82ade6acf9e50","_type":"span","marks":[],"text":"Tia is on a mission to improve women’s health outcomes in our country. In the context of declining health outcomes, it's critical to diagnose why, despite ever-increasing investment into the healthcare system, we’re seeing abysmal results. One reason for these worsening health outcomes is the unfortunate fact that 1 in 3 women in our country defer, or entirely abstain from, critical primary and preventive care services due to fears around unpredictable costs. Despite the fact that women are 40% more likely to have elevated disease burden relative to men (specifically, chronic conditions that primary care is best suited to manage) women are more likely than men to forgo necessary healthcare."}],"markDefs":[],"style":"normal"},{"_key":"5ff778496c01","_type":"block","children":[{"_key":"5b3d2d9c6ce80","_type":"span","marks":[],"text":"To achieve our mission of changing women’s health outcomes, we must address women foregoing necessary care. Fears of affordability, more precisely confusion of how healthcare coverage works, are behind this. Navigating the complexities of insurance and care affordability can be very scary, confusing, and stressful. It practically requires majoring in insurance to understand the nuances of coverage: in-network versus out-of-network, denials, co-pays, co-insurance, deductibles, why the same service costs more at one place versus another, etc. These complexities can lead to unexpected medical bills, followed by the stress and confusion of managing how to pay for these expenses. Unfortunately, Tia is not able to build a new model of medical insurance (at least not today), but we are able to help make these challenges a little less painful. Specifically, we can control how and when we charge you for your costs. We’re excited to introduce a new method of paying for healthcare that aims to bring ease and predictability to our members’ lives: Predictable Payments."}],"markDefs":[],"style":"normal"},{"_key":"1e3fa9822c7d","_type":"block","children":[{"_key":"69d0948a0a8b0","_type":"span","marks":[],"text":"What Is Predictable Payments?"}],"markDefs":[],"style":"h3"},{"_key":"11003c61b186","_type":"block","children":[{"_key":"9aa884e5ad280","_type":"span","marks":[],"text":"Predictable Payments is our new capped invoicing system that ensures that no matter the total amount you owe, you will only ever be billed $100 per month until your balance is paid off. Depending on the care you receive, this could look like: the total amount owed for care might be $300, but the total due this month is $100. This method offers a clear, manageable way to handle medical expenses, allowing you to focus on what truly matters—your health."}],"markDefs":[],"style":"normal"},{"_key":"4c235719aa48","_type":"block","children":[{"_key":"e14dc3b28e7e0","_type":"span","marks":[],"text":"Benefits of Predictable Payments"}],"markDefs":[],"style":"h3"},{"_key":"af59ff40759c","_type":"block","children":[{"_key":"08e024ae15b20","_type":"span","marks":["strong"],"text":"$100 Capped Invoices"}],"level":1,"listItem":"number","markDefs":[],"style":"normal"},{"_key":"68bcae6e7f32","_type":"block","children":[{"_key":"d943cd4213b80","_type":"span","marks":[],"text":"One of the most significant benefits of this new payment method is the predictability it brings. No more worrying about fluctuating monthly bills or unexpected charges. With a consistent cap of $100, you can easily budget and plan your finances with transparency around the total amount you owe. We recognize that you may need a few months to pay a balance, and that’s ok. We are here to support you getting the care you need when you need it. And we’re also are here to support you having the time you need to pay. Ultimately, we hope this helps unload the burden of feeling like you need to delay care to ensure you can pay for care."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"5fb9ca9a68d5","_type":"block","children":[{"_key":"791e628ee5110","_type":"span","marks":["strong"],"text":"One Invoice, One Time a Month"}],"level":1,"listItem":"number","markDefs":[],"style":"normal"},{"_key":"1dc0011b9768","_type":"block","children":[{"_key":"1c2b25eda1cb0","_type":"span","marks":[],"text":"The healthcare billing process can be complicated and confusing. Our new method simplifies this by providing clear, straightforward billing. You’ll receive a single, predictable invoice each month, making it easier to understand and manage your healthcare expenses."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"c02426a337ea","_type":"block","children":[{"_key":"95981725b48a0","_type":"span","marks":["strong"],"text":"Surprise-Free = Stress-Free"}],"level":1,"listItem":"number","markDefs":[],"style":"normal"},{"_key":"cc2a9dd45082","_type":"block","children":[{"_key":"2386a0e215f30","_type":"span","marks":[],"text":"Medical expenses can be overwhelming, especially when they come as a surprise. Our capped invoicing system alleviates this stress by spreading out payments into smaller, more manageable amounts. This approach helps prevent financial strain and ensures you can maintain financial stability."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"61dc9ed190e2","_type":"block","children":[{"_key":"25b6332664b60","_type":"span","marks":["strong"],"text":"Decision-Making For Your Health, Not Your Wallet"}],"level":1,"listItem":"number","markDefs":[],"style":"normal"},{"_key":"40a7d6a859c4","_type":"block","children":[{"_key":"8ef01802a12e0","_type":"span","marks":[],"text":"We believe in empowering our members with the tools and resources they need to make informed decisions about their health. Capped invoicing is part of our commitment to transparency and member-centric care. We aim to partner with you not just around the care you receive but also how you budget for the costs associated with the care you need and deserve."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"6f763da85afa","_type":"block","children":[{"_key":"9360e37860930","_type":"span","marks":[],"text":"Join Us in the Future of Making Paying for Healthcare "},{"_key":"9360e37860931","_type":"span","marks":["em"],"text":"Predictable"}],"markDefs":[],"style":"h3"},{"_key":"13b78a698d59","_type":"block","children":[{"_key":"ef66d03f18660","_type":"span","marks":[],"text":"The unpredictability of health insurance coverage presents an enormous and dangerous burden for patients. Improving health outcomes for women relies on women being able to get the care they need, and they need to be able to do so without fear. By introducing Predictable Payments, we’re taking a significant step towards simplifying the payment process and providing our members with a reliable and compassionate solution."}],"markDefs":[],"style":"normal"},{"_key":"e89daccce903","_type":"block","children":[{"_key":"1e1af59933890","_type":"span","marks":[],"text":"We invite you to experience the benefits of our new invoicing system. Together, we can make healthcare less daunting and more predictable. At Tia, we’re dedicated to supporting you every step of the way."}],"markDefs":[],"style":"normal"},{"_key":"9b23bb82fe8c","_type":"block","children":[{"_key":"5415dfe0bcbf0","_type":"span","marks":[],"text":"Please contact your care team for more information about our new payment method and how it can benefit you."}],"markDefs":[],"style":"normal"},{"_key":"57d2c3972f19","_type":"block","children":[{"_key":"a66407f2a8200","_type":"span","marks":[],"text":"Let’s move towards a healthier future—together."}],"markDefs":[],"style":"normal"},{"_key":"74c48ae57509","_type":"block","children":[{"_key":"15fe21a28020","_type":"span","marks":["5361b0515492"],"text":"Read our FAQ on Predictable Payments"}],"markDefs":[{"_key":"5361b0515492","_type":"internalLink","linkType":"text","reference":{"_id":"202d28d9-da7c-4185-9bcb-28e695b11214","_type":"page","_createdAt":"2024-08-09T17:22:21Z","_rev":"voAVeZs87becWOUzx1TX2K","_updatedAt":"2025-05-23T19:30:17Z","content":{"_type":"pageTabs","main":{"_type":"pageContent","modules":[{"_key":"c42133afe4283672c3ee5ebeff5550d9","_type":"spacer","backgroundColor":"bccream","spacing":"pys"},{"_key":"aa1a53b2fc9b","_type":"imageAndText","alignment":"jcrr","backgroundColor":"bccream","image":{"_type":"image","asset":{"_ref":"image-b9944e3c1f44e5c00287f2a3dcc09da538a8ec31-1200x864-png","_type":"reference"}},"spacing":"pys","style":"normal","text":[{"_key":"c33271fbd136","_type":"block","children":[{"_key":"c33755a5fe590","_type":"span","marks":[],"text":"Predictable Payments at Tia"}],"markDefs":[],"style":"h1"},{"_key":"71c9026c7ee9","_type":"block","children":[{"_key":"c19c29cef3180","_type":"span","marks":[],"text":"Predictable Payments is our new payment process, which ensures that no matter the total amount you owe, "},{"_key":"c19c29cef3181","_type":"span","marks":["strong"],"text":"you will only ever be billed a maximum of $100 per month until your balance is paid off"},{"_key":"c19c29cef3182","_type":"span","marks":[],"text":". "}],"markDefs":[],"style":"normal"},{"_key":"cf681bef9487","_type":"block","children":[{"_key":"5634f2f7cc19","_type":"span","marks":[],"text":"In our mission to improve women's health outcomes, and Predictable Payments is one step forward to helping women get the care they need without fear."}],"markDefs":[],"style":"normal"},{"_key":"57aaa632ff00","_type":"block","children":[{"_key":"cb7360c91ebe","_type":"span","marks":["1fafd0eaa5a6"],"text":"Read more about Predictable Payments"}],"markDefs":[{"_key":"1fafd0eaa5a6","_type":"internalLink","linkType":"text","reference":{"_ref":"b242f2b8-a163-4b20-b47a-df2db3f5bdfa","_type":"reference"}}],"style":"normal"}]},{"_key":"714cdedc7c18bdc032519270b4d20ce5","_type":"shape","backgroundColor":"secondary-2","shapeColor":"secondary-1","shapeType":"shape-3"},{"_key":"0c7e458fed5b8e76b90cf3deb7dea736","_type":"spacer","backgroundColor":"bcoat","spacing":"pym"},{"_key":"d7f812b99f0c","_type":"membershipCard","backgroundColor":"bcoat","spacing":"pys","text":[{"_key":"ffd8546d7d9b","_type":"block","children":[{"_key":"ba5681d8baff0","_type":"span","marks":[],"text":"Predictable Payments help you:"}],"markDefs":[],"style":"h3"},{"_key":"f849ae3fc45b","_type":"checkList","items":["Predict billing with $100 capped invoices.","Receive one simple, clear invoice each month.","Spread out manageable payments to reduce financial strain.","Make informed health decisions without worrying about payment."]}]},{"_key":"7f0fef7900ee","_type":"standardText","backgroundColor":"bcoat","spacing":"pys","text":[{"_key":"ad36934ad834","_type":"block","children":[{"_key":"b0fa204914370","_type":"span","marks":["strong"],"text":"Predictable Payments FAQ’s"}],"markDefs":[],"style":"h2"},{"_key":"c1ee2210783f","_type":"block","children":[{"_key":"791e8a78978c","_type":"span","marks":[],"text":"What Does this Mean to Me?"}],"markDefs":[],"style":"h4"},{"_key":"cb6285d0ec47","_type":"block","children":[{"_key":"99d609a86fc0","_type":"span","marks":[],"text":"One of the most significant benefits of this new payment method is the predictability it brings. No more worrying about fluctuating monthly bills or unexpected charges. With a consistent cap of $100, you can easily budget and plan your finances."}],"markDefs":[],"style":"normal"},{"_key":"020a9055bf39","_type":"block","children":[{"_key":"a65319b810f00","_type":"span","marks":[],"text":"How Does Predictable Payments Work?"}],"markDefs":[],"style":"h4"},{"_key":"7e1da2deab1d","_type":"block","children":[{"_key":"ac484bfed3cd0","_type":"span","marks":[],"text":"The way we work with your insurance will not change."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"abfc2b34206e","_type":"block","children":[{"_key":"c3742a38fac10","_type":"span","marks":[],"text":"Once you have a finalized invoice, you’ll be notified via email, as always."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"e6f38f1cdb41","_type":"block","children":[{"_key":"17ed677f26080","_type":"span","marks":[],"text":"If your out-of-pocket amount is "},{"_key":"17ed677f26081","_type":"span","marks":["strong"],"text":"less than "},{"_key":"17ed677f26082","_type":"span","marks":[],"text":"$100, your invoice will include the entire balance."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"cd813c79d01a","_type":"block","children":[{"_key":"a632b0714ffc0","_type":"span","marks":[],"text":"If your out-of-pocket amount is "},{"_key":"a632b0714ffc1","_type":"span","marks":["strong"],"text":"more than "},{"_key":"a632b0714ffc2","_type":"span","marks":[],"text":"$100, you’ll only receive an invoice for $100."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"9ddc341e47b1","_type":"block","children":[{"_key":"0d6fb46014580","_type":"span","marks":[],"text":"How Often Will I Be Invoiced?"}],"markDefs":[],"style":"h4"},{"_key":"2114f1edce54","_type":"block","children":[{"_key":"be01c4ca0dc00","_type":"span","marks":[],"text":"With Predictable Payments, you’ll receive an invoice for a maximum of $100 "},{"_key":"be01c4ca0dc01","_type":"span","marks":["strong"],"text":"once a month"},{"_key":"be01c4ca0dc02","_type":"span","marks":[],"text":" until your patient balance is paid in full."}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"52c6f5de9d84","_type":"block","children":[{"_key":"1dc570c171310","_type":"span","marks":[],"text":"EX 1: I have 3 $30 appointments with an outstanding balance"}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"24a597595fc3","_type":"block","children":[{"_key":"5ace2bd491660","_type":"span","marks":[],"text":"EX 2: I have 4 $30 appointments with an outstanding balance"}],"level":2,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"c754fbf64847","_type":"block","children":[{"_key":"f0eac8956f460","_type":"span","marks":[],"text":"How does Predictable Payments with Insurance?"}],"markDefs":[],"style":"h4"},{"_key":"88e336a75292","_type":"block","children":[{"_key":"ee947294b8db0","_type":"span","marks":[],"text":"For any new appointments, Tia will bill your insurance first to ensure you are billed the correct amount according to your plan benefits. Insurance typically takes 4-8 weeks to process your visit. Once Tia receives the finalized claim from your insurance, we will send you a copy of your bill via email."}],"markDefs":[],"style":"normal"},{"_key":"b1d04b3d6ff3","_type":"block","children":[{"_key":"a1b2675c3c250","_type":"span","marks":[],"text":"What Happens if I have Multiple Claims / Out-of-Pocket Expenses in a Month?"}],"markDefs":[],"style":"h4"},{"_key":"faa823a240b3","_type":"block","children":[{"_key":"b56c0aece96e0","_type":"span","marks":[],"text":"Tia’s billing team will manage this for you, and you will still only receive an invoice of $100 per month. "}],"markDefs":[],"style":"normal"},{"_key":"80ee57654b3c","_type":"block","children":[{"_key":"d9cb9eb7bdb20","_type":"span","marks":[],"text":"What Happens if I Cancel? "}],"markDefs":[],"style":"h4"},{"_key":"97b714d0f907","_type":"block","children":[{"_key":"9c11970ba0240","_type":"span","marks":[],"text":"If you cancel your membership before your annual term ends, Tia will send you a bill for any outstanding patient balance. If you have questions regarding payment options, please call the Care Team at (646) 650-5337 within 30 days."}],"markDefs":[],"style":"normal"},{"_key":"384ce456de0f","_type":"block","children":[{"_key":"276d6c34256a0","_type":"span","marks":[],"text":"For Balances Over $100, Where Can I See My Total Invoice Amount?"}],"markDefs":[],"style":"h4"},{"_key":"8675c408f121","_type":"block","children":[{"_key":"d4066cf4ef2e0","_type":"span","marks":[],"text":"You can log into your Tia Member Portal to view all invoices— including the balances you’ve paid off, and any outstanding balances you might have."}],"markDefs":[],"style":"normal"}]},{"_key":"47be2704d1a0662374356e1fcdb26260","_type":"shape","backgroundColor":"secondary-1","shapeColor":"secondary-2","shapeType":"shape-2"},{"_key":"573494cef2fc","_type":"standardText","backgroundColor":"bccream","spacing":"pym","text":[{"_key":"83259f7f463d","_type":"block","children":[{"_key":"26c2d2f836e8","_type":"span","marks":[],"text":"A New Era in Paying for Healthcare "}],"markDefs":[],"style":"h1"},{"_key":"53b8a49274fe","_type":"block","children":[{"_key":"5bacc8d159f5","_type":"span","marks":[],"text":"Tia is on a mission to improve women’s health outcomes in our country. To achieve our mission, we must address women foregoing necessary care. Fears of affordability, more precisely confusion of how healthcare coverage works, are behind this. We’re excited to introduce a new method of paying for healthcare that aims to bring ease and predictability to our members’ lives. "}],"markDefs":[],"style":"normal"},{"_key":"9cd9c43d3f4c","_type":"block","children":[{"_key":"8ab6845f137d","_type":"span","marks":["b69c0c75b3bc"],"text":"Read our blog post on Predictable Payments"}],"markDefs":[{"_key":"b69c0c75b3bc","_type":"internalLink","linkType":"text","reference":{"_ref":"b242f2b8-a163-4b20-b47a-df2db3f5bdfa","_type":"reference"}}],"style":"normal"}]},{"_key":"617adb5fa589","_type":"spacer","backgroundColor":"bccream","spacing":"pym"}],"slug":{"_type":"slug","current":"predictable-payments"},"title":"Predictable Payments - Page"},"meta":{"_type":"metaCard","metaTitle":"Predictable Payments","noIndex":true}},"id":"1a45a4c4-de8b-5d09-872e-0706df542f28","parent":null,"children":[],"internal":{"type":"SanityPage","contentDigest":"089ffe72d84a8494e922f9424ea868a2","counter":144,"owner":"gatsby-source-sanity"}}}],"style":"normal"}],"image":{"_type":"image","asset":{"_id":"image-ac288e5dbd1272ee0c78d5abe2916f0ba62b078e-4800x2112-png","_type":"sanity.imageAsset","_createdAt":"2024-08-09T22:26:11Z","_rev":"3jIp2YtR9edt9hnaAwVvf8","_updatedAt":"2024-08-09T22:26:11Z","assetId":"ac288e5dbd1272ee0c78d5abe2916f0ba62b078e","extension":"png","metadata":{"_type":"sanity.imageMetadata","blurHash":"M7CiR00@r9=n9G}OemE,9ws;0L=WK7kY-n","dimensions":{"_type":"sanity.imageDimensions","aspectRatio":2.272727272727273,"height":2112,"width":4800},"hasAlpha":true,"isOpaque":false,"lqip":"data:image/png;base64,","palette":{"